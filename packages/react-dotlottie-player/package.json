{
  "name": "@mhmmt/react-dotlottie-player",
  "version": "0.1.0",
  "description": "Play Lottie animations in React — supports both .json and .lottie files",
  "type": "module",
  "main": "./dist/react-dotlottie-player.cjs.js",
  "module": "./dist/react-dotlottie-player.esm.js",
  "types": "./dist/react-dotlottie-player.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-dotlottie-player.esm.js",
      "require": "./dist/react-dotlottie-player.cjs.js",
      "types": "./dist/react-dotlottie-player.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "lottie-web": "^5.12.2",
    "unzipit": "^1.4.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.4.2"
  },
  "keywords": [
    "react",
    "lottie",
    "dotlottie",
    "animation"
  ],
  "license": "MIT",
  "author": {
    "name": "Muhammet Andić",
    "email": "muhammet.andic@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammetandic/react-dotlottie-player.git"
  },
  "bugs": {
    "url": "https://github.com/muhammetandic/react-dotlottie-player/issues"
  }
}
