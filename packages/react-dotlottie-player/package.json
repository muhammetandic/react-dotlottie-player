{
  "name": "@mhmmt/react-dotlottie-player",
  "version": "0.1.0",
  "description": "Play Lottie animations in React — supports both .json and .lottie files",
  "type": "module",
  "main": "./dist/react-dotlottie-player.cjs.js",
  "module": "./dist/react-dotlottie-player.esm.js",
  "types": "./dist/react-dotlottie-player.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-dotlottie-player.esm.js",
      "require": "./dist/react-dotlottie-player.cjs.js",
      "types": "./dist/react-dotlottie-player.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "lottie-web": "^5.13.0",
    "unzipit": "^2.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "react",
    "lottie",
    "dotlottie",
    "animation"
  ],
  "license": "MIT",
  "author": {
    "name": "Muhammet Andić",
    "email": "muhammet.andic@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammetandic/react-dotlottie-player.git"
  },
  "bugs": {
    "url": "https://github.com/muhammetandic/react-dotlottie-player/issues"
  }
}
